# ────────────────────────────────────────────────────────────────
# Dependabot Vulnerability Tracker — environment template
# Copy to `.env` (or export in your shell) to enable optional features.
# Nothing in this file is required to run the dashboard or CLI; these
# only unlock extras.
# ────────────────────────────────────────────────────────────────

# LLM-powered deep analysis (scripts/run_deep_analysis.py)
# Without this, alerts get rule-based scoring only.
# Get a key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# LocalStack Pro token — only needed if you use LocalStack instead of Floci.
# Floci works without any auth; most users can leave this blank.
# Get a token at: https://app.localstack.cloud/
LOCALSTACK_AUTH_TOKEN=

# GitHub access — the dashboard uses `gh` CLI which reads its own auth.
# If running in CI without `gh`, fall back to a PAT with repo scope.
# GITHUB_TOKEN=
